{
    "swagger": "2.0",
    "info": {
        "description": "VantageOS backend — agent registry and task management.",
        "title": "VantageOS Core API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/agents/register": {
            "post": {
                "description": "Called by a physical agent on boot to register its identity and skills.\nThe request must include a pre-shared device API key as a Bearer token.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "agents"
                ],
                "summary": "Register an agent",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Bearer \u003cdevice-api-key\u003e",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Agent registration payload",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/cmd_core.registerRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/agent.RegisterResponse"
                        }
                    },
                    "400": {
                        "description": "bad request",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "401": {
                        "description": "unauthorized",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "internal server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/v1/tasks": {
            "post": {
                "description": "Dispatches a task to a named agent. The agent must be online and idle.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tasks"
                ],
                "summary": "Create a task",
                "parameters": [
                    {
                        "description": "Task payload",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/main.createTaskRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.createTaskResponse"
                        }
                    },
                    "400": {
                        "description": "bad request",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "409": {
                        "description": "agent offline or busy",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "internal server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "agent.RegisterResponse": {
            "type": "object",
            "properties": {
                "agent_id": {
                    "type": "string"
                },
                "grpc_addr": {
                    "type": "string"
                },
                "token": {
                    "type": "string"
                }
            }
        },
        "cmd_core.registerRequest": {
            "type": "object"
        },
        "main.createTaskRequest": {
            "type": "object",
            "properties": {
                "payload": {
                    "type": "object"
                },
                "robotId": {
                    "type": "string"
                },
                "type": {
                    "type": "string"
                }
            }
        },
        "main.createTaskResponse": {
            "type": "object",
            "properties": {
                "task_id": {
                    "type": "string"
                }
            }
        }
    }
}